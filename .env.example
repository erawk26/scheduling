# KE Agenda V3 - Environment Configuration
# Copy this file to .env.local and update with your values

# ============================================================================
# Database (PostgreSQL via Neon or local)
# ============================================================================
DATABASE_URL=postgresql://user:password@host:5432/dbname
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=keagenda
DATABASE_USER=keagenda
DATABASE_PASSWORD=your-database-password

# ============================================================================
# Better Auth
# ============================================================================
BETTER_AUTH_SECRET=your-secret-minimum-32-characters
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_DATABASE_URL=postgresql://user:password@host:5432/dbname

# ============================================================================
# Hasura GraphQL Engine
# ============================================================================
NEXT_PUBLIC_HASURA_URL=http://localhost:8080/v1/graphql
HASURA_GRAPHQL_ENDPOINT=http://localhost:8080/v1/graphql
HASURA_ADMIN_SECRET=your-hasura-admin-secret
# JWT verification via JWKS (Better Auth exposes /api/auth/jwks)
# For development, Hasura fetches JWKS from the Next.js app
# HASURA_GRAPHQL_JWT_SECRET is configured in docker-compose.yml via jwk_url
# In production, replace host.docker.internal with your actual domain

# ============================================================================
# Public App URL
# ============================================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================================================
# Weather Integration (Tomorrow.io)
# ============================================================================
TOMORROW_IO_API_KEY=your-tomorrow-io-api-key

# ============================================================================
# GraphHopper (Route Optimization + Geocoding)
# ============================================================================
GRAPHHOPPER_API_KEY=your-graphhopper-api-key

# ============================================================================
# OAuth Providers (optional)
# ============================================================================
GOOGLE_CLIENT_ID=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ============================================================================
# Environment
# ============================================================================
NODE_ENV=development
LOG_LEVEL=debug
