{
  "name": "ke-agenda-sync-worker",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create ke-agenda-sync",
    "db:migrate": "wrangler d1 execute ke-agenda-sync --file=schema.sql",
    "db:migrate:remote": "wrangler d1 execute ke-agenda-sync --remote --file=schema.sql"
  },
  "dependencies": {
    "hono": "^4.12.8"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241218.0",
    "typescript": "^5.7.3",
    "wrangler": "^3.114.17"
  }
}
